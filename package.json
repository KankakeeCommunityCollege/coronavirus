{
  "name": "coronavirus",
  "version": "2.0.0",
  "description": "",
  "private": true,
  "babel": {
    "presets": [
      "@babel/preset-env"
    ],
    "plugins": [
      [
        "polyfill-corejs3",
        {
          "method": "usage-global",
          "version": "3.37",
          "proposals": true
        }
      ]
    ]
  },
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "production": "run-p jekyll-production webpack-production",
    "development": "run-p jekyll-development webpack-dev",
    "jekyll-production": "JEKYLL_ENV=production bundle exec jekyll serve --livereload",
    "jekyll-development": "bundle exec jekyll serve --livereload",
    "webpack-production": "npx webpack --watch --mode production",
    "webpack-dev": "npx webpack --watch --mode development",
    "browserslist": "npx browserslist@latest --update-db",
    "test:pa11y": "bash pa11y.sh",
    "test:pa11y-ci": "bash pa11y-ci.sh",
    "test:pa11y-ci-log": "bash pa11y-ci.sh -o"
  },
  "author": "https://github.com/wdzajicek",
  "license": "ISC",
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "autoprefixer": "^10.2.6",
    "babel-loader": "^10.0.0",
    "babel-plugin-polyfill-corejs3": "^1.0.0",
    "css-loader": "^7.1.2",
    "mini-css-extract-plugin": "^2.9.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.3.4",
    "postcss-loader": "^8.1.1",
    "sass-embedded": "^1.80.4",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "url-loader": "^4.1.1",
    "webpack": "^5.93.0",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "colors": "1.4.0",
    "core-js": "^3.6.5",
    "regenerator-runtime": "^0.14.1"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "core-js@3.49.0": true,
    "fsevents@2.3.3": true
  }
}
